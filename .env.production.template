# Kaffeegraf B2B Landing Page - Production Environment Template
# For Hostinger Deployment
# Version: 306d5902
# Date: April 3, 2026

# ============================================
# CORE APPLICATION
# ============================================
NODE_ENV=production
PORT=3000

# ============================================
# DATABASE (MySQL / TiDB)
# ============================================
# Provided by Manus - do not change
DATABASE_URL=<SET_THIS_IN_HOSTINGER>

# ============================================
# AUTHENTICATION & SECURITY
# ============================================
# Provided by Manus - do not change
JWT_SECRET=<SET_THIS_IN_HOSTINGER>
VITE_APP_ID=<SET_THIS_IN_HOSTINGER>
OAUTH_SERVER_URL=<SET_THIS_IN_HOSTINGER>
VITE_OAUTH_PORTAL_URL=<SET_THIS_IN_HOSTINGER>
OWNER_OPEN_ID=<SET_THIS_IN_HOSTINGER>
OWNER_NAME=<SET_THIS_IN_HOSTINGER>

# ============================================
# MANUS FORGE API (Built-in Services)
# ============================================
# Provided by Manus - do not change
BUILT_IN_FORGE_API_URL=<SET_THIS_IN_HOSTINGER>
BUILT_IN_FORGE_API_KEY=<SET_THIS_IN_HOSTINGER>
VITE_FRONTEND_FORGE_API_KEY=<SET_THIS_IN_HOSTINGER>
VITE_FRONTEND_FORGE_API_URL=<SET_THIS_IN_HOSTINGER>

# ============================================
# EMAIL / MAIL CONFIGURATION
# ============================================
# CRITICAL: Use real mailbox (team@kaffeegraf.coffee), not alias (b2b@...)
# For Hostinger SMTP:

MAIL_HOST=smtp.hostinger.com
MAIL_PORT=465
MAIL_USER=team@kaffeegraf.coffee
MAIL_PASSWORD=<SET_THIS_IN_HOSTINGER>
MAIL_FROM=team@kaffeegraf.coffee

# Note: Code automatically sets secure=true when port=465

# ============================================
# WOOCOMMERCE INTEGRATION
# ============================================
# Required for B2B access and customer management

WOOCOMMERCE_URL=https://kaffeegraf.coffee
WOOCOMMERCE_CONSUMER_KEY=<SET_THIS_IN_HOSTINGER>
WOOCOMMERCE_CONSUMER_SECRET=<SET_THIS_IN_HOSTINGER>

# ============================================
# TRACKING & ANALYTICS (Optional)
# ============================================
# Only set if you want to enable tracking

VITE_GA_ID=<OPTIONAL>
VITE_META_PIXEL_ID=<OPTIONAL>

# ============================================
# VAT VALIDATION (Optional)
# ============================================
# Only needed if VAT validation is active

VIES_API_KEY=<OPTIONAL>
VIES_API_KEY_ID=<OPTIONAL>

# ============================================
# ANALYTICS ENDPOINT (Optional)
# ============================================
# Only needed if custom analytics is configured

VITE_ANALYTICS_ENDPOINT=<OPTIONAL>
VITE_ANALYTICS_WEBSITE_ID=<OPTIONAL>

# ============================================
# HOSTINGER SPECIFIC VARIABLES
# ============================================
# These are automatically injected by Manus on Hostinger
# Do NOT set manually - they override the above values

# HOSTINGER_DATABASE_URL=...
# HOSTINGER_JWT_SECRET=...
# HOSTINGER_OAUTH_SERVER_URL=...
# HOSTINGER_VITE_OAUTH_PORTAL_URL=...
# HOSTINGER_BUILT_IN_FORGE_API_URL=...
# HOSTINGER_BUILT_IN_FORGE_API_KEY=...
# HOSTINGER_VITE_FRONTEND_FORGE_API_KEY=...
# HOSTINGER_VITE_FRONTEND_FORGE_API_URL=...
# HOSTINGER_VITE_APP_ID=...
# HOSTINGER_OWNER_OPEN_ID=...

# ============================================
# DEPLOYMENT INSTRUCTIONS
# ============================================
# 1. Copy this file to .env.production on Hostinger
# 2. Replace all <SET_THIS_IN_HOSTINGER> placeholders
# 3. Keep <OPTIONAL> placeholders as-is if not using those features
# 4. Verify all CRITICAL variables are set
# 5. Test email sending before going live
# 6. Restart the application

# ============================================
# VERIFICATION CHECKLIST
# ============================================
# Before deployment, verify:
# [ ] DATABASE_URL is set and accessible
# [ ] JWT_SECRET is a strong, random string
# [ ] MAIL_USER = team@kaffeegraf.coffee (real mailbox)
# [ ] MAIL_PASSWORD is correct for team@ mailbox
# [ ] WOOCOMMERCE credentials are valid
# [ ] All CRITICAL variables have values (no <SET_THIS_IN_HOSTINGER> remaining)
# [ ] NODE_ENV = production
# [ ] PORT = 3000
